{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/rules.md"
  ],
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "opencode-codebase-index": {
      "type": "local",
      "command": [
        "opencode-codebase-index-mcp"
      ],
      "enabled": true
    },
    "codesight": {
      "type": "local",
      "command": [
        "codesight",
        "--mcp"
      ],
      "enabled": true
    },
    "aptu-coder": {
      "type": "local",
      "command": [
        "aptu-coder"
      ],
      "enabled": true
    }
  }
}
